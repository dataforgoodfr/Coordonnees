{
  "layers": [
    {
      "id": "satellite",
      "type": "xyzservices",
      "provider": "Esri.WorldImagery"
    },
    {
      "id": "villages",
      "type": "openmaptiles",
      "layer": "place",
      "filters": {
        "class": "village"
      }
    },
    {
      "id": "towns",
      "type": "openmaptiles",
      "layer": "place",
      "filters": {
        "class": "town"
      }
    },
    {
      "id": "boundaries",
      "type": "openmaptiles",
      "layer": "boundary",
      "filters": {
        "admin_level": 2
      },
      "style": {
        "paint": {
          "line-color": "hsl(248,7%,66%)"
        }
      }
    },
    {
      "id": "inventaire",
      "type": "datapackage",
      "path": "../catalog/inventaire_for",
      "resource": "inv_for",
      "layerType": "symbol",
      "columns": {
        "geom": "gps.merge().centroid()",
        "for": "loc2",
        "cod": "cod",
        "taille_placette": "20^2*pi()/10000",
        "projet": "trim('A Kob Ale')",
        "biomass_volume": "adu.sum(0.0673 * (for_sp.dens * (meas1 + meas2 + meas3 + meas4 + meas5 + meas6 + meas7 + meas8 + meas9 + meas10)^2 * hgt_perp)^0.976 if cond = 1) / (20^2 * pi() / 10000) / 1000",
        "tree_density": "count(1 if adu.cond = 1) / 0.1256",
        "tree_pop": "count(1 if adu.cond = 1)",
        "richness": "count(unique(adu.adu_sp))",
        "relative_abundance": "histogram(adu.adu_sp)",
        "epf_tree_density": "count(1 if adu.cond = 1) / (20^2 * pi() / 10000) / 1000",
        "epf_necromass_pied": "adu.sum(0.0673 * (for_dw.dens * (meas1 + meas2 + meas3 + meas4 + meas5 + meas6 + meas7 + meas8 + meas9 + meas10)^2 * hgt_perp)^0.976 if cond = 2)",
        "epf_necromass_sol": "adu.sum(3.1415926535 / 3 * ((meas_b / 2)^2 + ((meas_e / 2)^2 + meas_b / 2 + meas_e / 2) * lght * for_dw.dens) if cond = 3)",
        "epf_deadWood": "((adu.sum(0.0673 * (for_dw.dens * (meas1 + meas2 + meas3 + meas4 + meas5 + meas6 + meas7 + meas8 + meas9 + meas10)^2 * hgt_perp)^0.976 if cond = 2) + adu.sum(pi() / 3 * ((meas_b / 2)^2 + ((meas_e / 2)^2 + meas_b / 2 + meas_e / 2) * lght * for_dw.dens) if cond = 3)) / adu.sum(0.0673 * (for_sp.dens * (meas1 + meas2 + meas3 + meas4 + meas5 + meas6 + meas7 + meas8 + meas9 + meas10)^2 * hgt_perp)^0.976 if cond = 1)) * 10",
        "epf_tree_diversity": "shannon(adu.adu_sp) / 5 * 10",
        "epf_spatial_distribution": "adu.categorical_gini(area) * 10",
        "epf_diameter_distribution": "adu.gini(meas1 + meas2 + meas3 + meas4 + meas5 + meas6 + meas7 + meas8 + meas9 + meas10) * 10",
        "epf_vertical_distribution": "gini(adu.hgt_perp) * 10",
        "epf_dominant_height": "adu.avg(hgt_perp if hgt_perp > percentile(hgt_perp, 80)) * 10 / 40",
        "epf_microhabitats": "adu.list(trem).flatten().list_unique() * 10 / trem_group_max",
        "soil_structure": "sum(thk1*int(not1) + thk2*int(not2) + thk3*int(not3) + thk4*int(not4) + thk5*int(not5)) / sum(thk1 + thk2 + thk3 + thk4 + thk5) * 2",
        "soil_composition": "count(1)",
        "ero_rainfall_and_wind": "for_weath.concat_ws('-', rain, wind)",
        "ero_couv_slope_and_cover": "concat_ws('-', '8', '10')",
        "ero_soil_stability": "(int(slak1) + int(slak2) + int(slak3)) / 3",
        "ero_water_seepage": "concat_ws('','BEER data type changed from integer to datetime', '')",        "soil_fauna_density": "sum(tsbf_001.tsbf_no) / 20^2 * pi() / 10000",
        "soil_fauna_diversity": "list_unique(list(tsbf_001.concat_ws('-', tsbf_tax1, tsbf_tax2, tsbf_tax3)))",
        "soil_fauna_abundance_tax1": "histogram(tsbf_001.tsbf_tax1)",
        "soil_fauna_abundance_tax2": "histogram(tsbf_001.tsbf_tax2)",
        "soil_fauna_abundance_tax3": "histogram(tsbf_001.tsbf_tax3)",
        "surface_fauna_density": "sum(barba_001.barbA_no + barbb_001.barbB_no + barbc_001.barbC_no + barbd_001.barbD_no) / 20^2 * pi() / 10000",
        "surface_fauna_diversity": "list_unique(list_concat(list(barba_001.concat_ws('-', barbA_tax1, barbA_tax2, barbA_tax3)), list(barbb_001.concat_ws('-', barbB_tax1, barbB_tax2, barbB_tax3)), list(barbc_001.concat_ws('-', barbC_tax1, barbC_tax2, barbC_tax3)), list(barbd_001.concat_ws('-', barbD_tax1, barbD_tax2, barbD_tax3))))",
        "surface_fauna_abundance_tax1": "list_aggregate(list_concat(list(barba_001.barbA_tax1), list(barbb_001.barbB_tax1), list(barbc_001.barbC_tax1), list(barbd_001.barbD_tax1)), 'histogram')",
        "surface_fauna_abundance_tax2": "list_aggregate(list_concat(list(barba_001.barbA_tax2), list(barbb_001.barbB_tax2), list(barbc_001.barbC_tax2), list(barbd_001.barbD_tax2)), 'histogram')",
        "surface_fauna_abundance_tax3": "list_aggregate(list_concat(list(barba_001.barbA_tax3), list(barbb_001.barbB_tax3), list(barbc_001.barbC_tax3), list(barbd_001.barbD_tax3)), 'histogram')",
        "surface_fauna_abundance": "list_aggregate(list_concat(list(barba_001.concat_ws('-', barbA_tax1, barbA_tax2, barbA_tax3)), list(barbb_001.concat_ws('-', barbB_tax1, barbB_tax2, barbB_tax3)), list(barbc_001.concat_ws('-', barbC_tax1, barbC_tax2, barbC_tax3)), list(barbd_001.concat_ws('-', barbD_tax1, barbD_tax2, barbD_tax3))), 'histogram')",
        "soil_fauna_abundance": "list_aggregate(list(tsbf_001.concat_ws('-', tsbf_tax1, tsbf_tax2, tsbf_tax3)), 'histogram')"
      },
      "popup": {
        "trigger": "click"
      }
    },
    {
      "id": "enquete",
      "type": "datapackage",
      "path": "../catalog/enquete",
      "resource": "enquete_menage",
      "layerType": "symbol",
      "groupby": ["loc2"],
      "columns": {
        "geom": "centroid(merge(point(enq_gps.long, enq_gps.latit)))",
        "household_nb": "count(_id)",
        "population": "sum(res)",
        "energyType": "count(ener)",
        "boughtWoodEnergy": "count(1)",
        "coalEnergy": "count(1)",
        "organicWasteEnergy": "count(1)",
        "animalWasteEnergy": "count(1)",
        "gasEnergy": "count(1)",
        "otherEnergy": "count(1)",
        "woodEnergyConsumption": "count(1)",
        "woodEnergyNeeds": "count(1)",
        "woodCollectionTime": "count(1)",
        "timberNeeds": "count(1)",
        "foodDiversity": "count(1)",
        "autoConsumtionNeeds": "count(1)",
        "hungryGap": "count(1)",
        "incomeSources": "count(1)",
        "incomeEvolution": "count(1)",
        "estateIndex": "count(1)",
        "livingConditionsPercreption": "count(1)",
        "conflictIndex": "count(1)",
        "beneficialPractices": "count(1)"
      },
      "popup": {
        "trigger": "click"
      }
    },
    {
      "id": "seed",
      "type": "datapackage",
      "path": "../catalog/seed/datapackage.json",
      "resource": "survey",
      "minzoom": 13,
      "columns": {
        "geom": "geom",
        "id": "OGC_FID",
        "orga": "votre_orga",
        "responsable": "nom_du_res",
        "date_plantation": "date_de_pl",
        "type_plant": "type_de_pl",
        "prelevement_mangrove": "trace_de_p",
        "test": "round(random() * 4 ) + 1"
      },
      "paint": {
        "fill-color": [
          "interpolate",
          ["linear"],
          ["number", ["get", "test"]],
          1, "#2DC4B2",
          2, "#3BB3C3",
          3, "#669EC4",
          4, "#A2719B",
          5, "#AA5E79"
        ],
        "fill-opacity": 0.8
      },
      "popup": {
        "trigger": "click"
      }
    },
    {
      "id": "seed_point",
      "type": "datapackage",
      "path": "../catalog/seed/datapackage.json",
      "resource": "survey",
      "columns": {
        "geom": "centroid(geom)"
      },
      "maxzoom": 13
    }
  ],
  "controls": [
    {
      "type": "compass",
      "position": "top-left"
    },
    {
      "type": "layer",
      "position": "top-right"
    },
    {
      "type": "scale",
      "position": "bottom-left"
    }
  ]
}
